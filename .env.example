# =============================================================================
# Digital FTE Agent — Environment Configuration
# Copy to .env and fill in actual values. NEVER commit .env to git.
# =============================================================================

# --- Vault ---
VAULT_PATH=/path/to/your/AI_Employee_Vault

# --- Gmail Watcher ---
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_TOKEN_PATH=/path/to/token.json

# --- WhatsApp Watcher ---
WHATSAPP_SESSION_PATH=/path/to/whatsapp_session

# --- Facebook / Instagram Watchers (browser-based, no API token needed) ---
FACEBOOK_SESSION_PATH=credentials/facebook_session
FACEBOOK_KEYWORDS=urgent,asap,invoice,payment,help,deadline,meeting,contract,quote,proposal
INSTAGRAM_SESSION_PATH=credentials/instagram_session
INSTAGRAM_KEYWORDS=urgent,asap,invoice,payment,help,collab,collaboration,price,order

# --- Finance Watcher ---
BANK_CSV_DROP_PATH=/path/to/bank_csv_drop_folder
FILE_DROP_PATH=/path/to/file_drop_folder

# --- Odoo ERP (Gold+) ---
ODOO_URL=http://localhost:8069
ODOO_DB=mycompany
ODOO_USERNAME=admin
ODOO_API_KEY=your_odoo_api_key_here

# --- Social Media Posting (Gold+) ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_AUTHOR_URN=urn:li:person:your_person_id
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_CONSUMER_KEY=your_api_key
TWITTER_CONSUMER_KEY_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token

# --- Agent Control ---
# Set to false only after thorough testing. Default true for safety.
DRY_RUN=true
MAX_ITERATIONS=10

# --- Agent Mode (Platinum) ---
# Values: local | cloud
AGENT_MODE=local
CLOUD_AGENT_ID=local-01

# --- Vault Git Sync (Platinum) ---
VAULT_GIT_REMOTE=git@github.com:username/ai-employee-vault.git
VAULT_SYNC_INTERVAL_MINUTES=15
