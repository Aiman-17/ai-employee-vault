# =============================================================================
# Digital FTE Agent — Cloud VM Environment Configuration
# Copy to .env on the Cloud VM and fill in actual values.
# NEVER commit this file. NEVER include WhatsApp or banking credentials.
#
# Constitution Article IX: Cloud agent is DRAFT-ONLY.
#   - No BANK_API_TOKEN (payment execution is Local-only)
#   - No WHATSAPP_SESSION_PATH (WhatsApp session is Local-only)
# =============================================================================

# --- Agent Identity ---
AGENT_MODE=cloud
CLOUD_AGENT_ID=cloud-01

# --- Vault ---
VAULT_PATH=/home/ubuntu/AI_Employee_Vault

# --- Vault Git Sync ---
VAULT_GIT_REMOTE=git@github.com:<your_username>/ai-employee-vault.git
VAULT_SYNC_INTERVAL_MINUTES=15

# --- Gmail (Cloud triages + drafts; Local sends) ---
GMAIL_CLIENT_ID=<your_client_id>
GMAIL_CLIENT_SECRET=<your_client_secret>
GMAIL_TOKEN_PATH=credentials/gmail_token.json
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# --- Finance Watcher ---
BANK_CSV_DROP_PATH=/home/ubuntu/AI_Employee_Vault/Accounting/drops
FILE_DROP_PATH=/home/ubuntu/AI_Employee_Vault/Inbox

# --- Odoo ERP (Cloud: draft-only actions; Local approves posting) ---
ODOO_URL=http://<cloud_vm_ip>:8069
ODOO_DB=mycompany
ODOO_USERNAME=admin
ODOO_API_KEY=<your_odoo_api_key>

# --- LinkedIn (Cloud drafts posts; queued for Local approval) ---
LINKEDIN_ACCESS_TOKEN=<your_linkedin_token>

# --- Twitter/X (Cloud drafts; Local approves) ---
TWITTER_BEARER_TOKEN=<your_bearer_token>
TWITTER_CONSUMER_KEY=<your_consumer_key>
TWITTER_SERET_KEY=<your_api_secret>
TWITTER_ACCESS_TOKEN=<your_access_token>
TWITTER_ACCESS_TOKEN_SECRET=<your_access_token_secret>

# --- Safety ---
DRY_RUN=true
MAX_ITERATIONS=10
PYTHONIOENCODING=utf-8

# =============================================================================
# INTENTIONALLY OMITTED (Local-only credentials — NEVER put these on cloud VM):
#   BANK_API_TOKEN         — banking credentials (Local only)
#   WHATSAPP_SESSION_PATH  — WhatsApp session (Local only)
#   FACEBOOK_ACCESS_TOKEN  — if used, keep Local only
# =============================================================================
